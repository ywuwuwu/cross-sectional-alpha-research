{
  "type": "object",
  "required": [
    "factor_name",
    "reproduction_mode",
    "formula_level",
    "data_mapping",
    "implementation",
    "backtest",
    "results",
    "assumptions",
    "conclusion"
  ],
  "properties": {
    "factor_name": { "type": "string" },
    "source_report": { "type": "string" },
    "reproduction_mode": {
      "type": "string",
      "enum": ["exact_reproduction", "local_data_reproduction"]
    },
    "formula_level": {
      "type": "object",
      "properties": {
        "report_formula": { "type": "string" },
        "implemented_formula": { "type": "string" },
        "differences": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["report_requirement", "local_source", "local_field", "status"],
        "properties": {
          "report_requirement": { "type": "string" },
          "local_source": { "type": "string" },
          "local_field": { "type": "string" },
          "transformation": { "type": "string" },
          "status": { "type": "string" },
          "assumption_or_risk": { "type": "string" }
        }
      }
    },
    "implementation": {
      "type": "object",
      "properties": {
        "strategy_file": { "type": "string" },
        "strategy_class": { "type": "string" },
        "runner_command": { "type": "string" }
      }
    },
    "backtest": {
      "type": "object",
      "properties": {
        "start_date": { "type": "string" },
        "end_date": { "type": "string" },
        "rebalance_freq": {},
        "top_n": { "type": "integer" },
        "n_groups": { "type": "integer" },
        "costs_enabled": { "type": "boolean" }
      }
    },
    "results": {
      "type": "object",
      "properties": {
        "total_return": { "type": ["number", "null"] },
        "annual_return": { "type": ["number", "null"] },
        "sharpe_ratio": { "type": ["number", "null"] },
        "max_drawdown": { "type": ["number", "null"] },
        "ic_mean": { "type": ["number", "null"] },
        "ic_std": { "type": ["number", "null"] },
        "ir": { "type": ["number", "null"] },
        "ic_win_rate": { "type": ["number", "null"] },
        "stable_layering": { "type": ["boolean", "null"] }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "conclusion": { "type": "string" }
  }
}
